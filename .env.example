# Docker Compose environment (copy to .env before: docker compose up --build)
# Do NOT commit .env with real production secrets.

# PostgreSQL container credentials
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory

# Backend (DATABASE_URL is set automatically in docker-compose.yml)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
LOW_STOCK_THRESHOLD=10

# Frontend build-time API URL (browser calls host machine port 8000)
VITE_API_BASE_URL=http://localhost:8000
